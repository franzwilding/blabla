<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Bundle identity -->
    <key>CFBundleIdentifier</key>
    <string>com.blabla.app</string>
    <key>CFBundleName</key>
    <string>Blabla</string>
    <key>CFBundleDisplayName</key>
    <string>Blabla</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>CFBundleExecutable</key>
    <string>Blabla</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleIconName</key>
    <string>AppIcon</string>

    <!-- Menu-bar-only app: no Dock icon, no menu bar application menu -->
    <key>LSUIElement</key>
    <true/>

    <!-- Minimum macOS version (macOS 26 Tahoe) -->
    <key>LSMinimumSystemVersion</key>
    <string>26.0</string>

    <!-- Privacy usage descriptions -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Blabla uses the microphone to transcribe your speech in real time.</string>

    <!-- ScreenCaptureKit requires this for system audio capture -->
    <key>NSScreenCaptureDescription</key>
    <string>Blabla captures system audio to transcribe what you hear in real time.</string>

    <key>NSSpeechRecognitionUsageDescription</key>
    <string>Blabla uses on-device speech recognition to transcribe audio.</string>

    <key>NSAccessibilityUsageDescription</key>
    <string>Blabla uses Accessibility to detect the Fn key globally for push-to-talk and toggle recording.</string>

    <!-- High-resolution display support -->
    <key>NSHighResolutionCapable</key>
    <true/>

    <!-- Supports the dark/light appearance -->
    <key>NSRequiresAquaSystemAppearance</key>
    <false/>
</dict>
</plist>
